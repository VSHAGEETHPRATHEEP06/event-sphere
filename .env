# ──────────────────────────────────────────────
# EventSphere Environment Variables
# Copy this file to .env and update values
# ──────────────────────────────────────────────

# Database
DB_USER=eventsphere
DB_PASSWORD=eventsphere_secret

# JWT
JWT_SECRET=eventsphere_jwt_super_secret_key_2026
JWT_EXPIRES_IN=24h

# Redis
REDIS_PASSWORD=redis_secret

# RabbitMQ
RABBITMQ_USER=eventsphere
RABBITMQ_PASSWORD=rabbitmq_secret

# SMTP (Email - Use Ethereal for testing: https://ethereal.email)
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@eventsphere.com
